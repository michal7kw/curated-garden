# curated_garden — build-time environment variables
#
# This file is a SCHEMA REFERENCE, not a working .env. The actual values are
# maintained in two places:
#
#   1. Vercel dashboard (https://vercel.com/michals-projects-f3b8b371/curated-garden/settings/environment-variables)
#      → authoritative source — overrides (2) on build
#   2. michal7kw/curated-garden deploy repo's `.env` (committed there)
#      → build-time fallback / default configuration
#
# HELPERS/scripts/deploy-garden.sh preserves the deploy repo's .env (does NOT
# overwrite from monorepo), so committing values here would be a no-op for
# deploys. Use this file only to:
#   - Understand what the build needs
#   - Match the schema when reviewing deploy repo .env changes
#   - Onboard a new developer: they can copy this → .env for local preview builds
#
# For a local preview build (`bun run build`), copy this to `.env` and fill in
# values. Do NOT commit the filled-in .env — it's gitignored at the monorepo root.

# =============================================================================
# Site identity
# =============================================================================

SITE_NAME_HEADER=Digital Garden          # shown in <title> and sidebar header
SITE_MAIN_LANGUAGE=en                    # <html lang="..."> attribute
SITE_BASE_URL=                           # full base URL if serving under a subpath; blank for root

# =============================================================================
# Theme
# =============================================================================

# Obsidian community theme URL (loaded at build time via src/site/get-theme.js).
# Any Obsidian theme CSS that lives at a raw-content GitHub URL works here.
THEME=https://raw.githubusercontent.com/seanwcom/Red-Graphite-for-Obsidian/HEAD/theme.css

BASE_THEME=dark                          # dark | light — affects <body> class

# =============================================================================
# Timestamps on note pages
# =============================================================================

SHOW_CREATED_TIMESTAMP=false             # show "Created: ..." on each note
SHOW_UPDATED_TIMESTAMP=false             # show "Updated: ..." on each note
TIMESTAMP_FORMAT=MMM dd, yyyy h:mm a     # Luxon format string

# =============================================================================
# Icon display toggles (Note icon from frontmatter)
# =============================================================================

NOTE_ICON_DEFAULT=                       # blank or emoji — used when frontmatter has no icon
NOTE_ICON_TITLE=false                    # show icon next to title
NOTE_ICON_FILETREE=false                 # show icon in left-sidebar filetree
NOTE_ICON_INTERNAL_LINKS=false           # show icon in internal [[wiki-links]]
NOTE_ICON_BACK_LINKS=false               # show icon in the "Links to this page" backlink list

# =============================================================================
# Style settings (optional CSS customization)
# =============================================================================

STYLE_SETTINGS_CSS=                      # additional CSS string injected into <head>
STYLE_SETTINGS_BODY_CLASSES=             # extra classes added to <body> element

# =============================================================================
# Assets
# =============================================================================

USE_FULL_RESOLUTION_IMAGES=false         # false = images downscaled via eleventy-img; true = keep original

# =============================================================================
# Digital Garden plugin settings (feature toggles)
# =============================================================================

dgHomeLink=true                          # render top navbar with home link (else uses .empty-navbar)
dgPassFrontmatter=false                  # if true, passes original frontmatter to Eleventy for each note
dgShowBacklinks=true                     # render "Links to this page" footer on notes
dgShowLocalGraph=true                    # render the per-note local graph visualization
dgShowInlineTitle=false                  # render H1 inline with note content
dgShowFileTree=true                      # render the left-sidebar filetree
dgEnableSearch=true                      # enable Ctrl+K search + search button in navbar
dgShowToc=true                           # render the table of contents for long notes
dgLinkPreview=true                       # enable hover-preview cards for internal links
dgShowTags=true                          # render #tags under each note's title
